{
  "expo": {
    "name": "messengerApp",
    "slug": "messengerApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/avt.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.messengerApp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/avt.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.messengerApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b3a1218f-1582-46ec-a050-ca26322e6182"
      }
    },
    "owner": "nguyenhuutruong6666",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}